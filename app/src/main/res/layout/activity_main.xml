<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#222222"
    android:padding="12dp"
    tools:context=".MainActivity">

    <!-- Pantalla donde se ven los números -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:padding="12dp">

        <TextView
            android:id="@+id/textoArriba"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="textEnd"
            android:textColor="#888888"
            android:textSize="24sp"
            android:hint="0.0"
            android:textColorHint="#555555" />

        <TextView
            android:id="@+id/textoAbajo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="textEnd"
            android:textColor="#FFFFFF"
            android:textSize="52sp"
            android:hint="0.0"
            android:textColorHint="#666666" />
    </LinearLayout>

    <!-- Botón para limpiar todo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/botonBorrar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="C"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444444" />
    </LinearLayout>

    <!-- Tercera fila de números con suma -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/boton7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="7"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/boton8"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="8"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/boton9"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="9"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/botonSumar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="clickOperacion"
            android:text="+"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C0392B" />
    </LinearLayout>

    <!-- Segunda fila de números con resta -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/boton4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="4"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/boton5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="5"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/boton6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="6"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/botonRestar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="clickOperacion"
            android:text="-"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C0392B" />
    </LinearLayout>

    <!-- Primera fila de números con multiplicación -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/boton1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="1"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/boton2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="2"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/boton3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="3"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/botonMultiplicar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="clickOperacion"
            android:text="x"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C0392B" />
    </LinearLayout>

    <!-- Última fila: cero grande, punto, igual y división -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button
            android:id="@+id/boton0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="0"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/botonPunto"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:onClick="presionarDigito"
            android:text="."
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/botonIgual"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="="
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A3A3A" />

        <Button
            android:id="@+id/botonDividir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:onClick="clickOperacion"
            android:text="/"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C0392B" />
    </LinearLayout>

</LinearLayout>